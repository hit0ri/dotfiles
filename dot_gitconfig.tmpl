[user]
	email = {{ .email }}
	name = {{ .name }}
	signingKey = {{ .signingkey }}

[init]
	defaultBranch = main

[core]
	commitGraph = false
	excludesFile = ~/.gitignore

[commit]
	verbose = true
	gpgSign = true

[log]
	date = relative

[format]
	pretty = format:%C(bold blue)%h%C(reset) %C(green)%ad%C(reset) %s %C(dim white)%aN%C(reset) %C(yellow)%D%C(reset)

[pull]
	ff = only

[push]
	default = simple

[alias]
	pf = push --force-with-lease
	co = checkout
	cob = checkout -b
	ap = add --patch
	c = commit
	cm = commit -m
	ca = commit --amend
	can = commit --amend --no-edit
	cam = commit --amend -m
	cloneb = clone --filter=blob:none
	clonet = clone --filter=tree:0
	d = diff --stat
	ds = diff --staged --stat
	dst = diff --staged
	st = status -sb
	br = branch
	type = cat-file -t
	dump = cat-file -p
	last = log -1 HEAD
	lastf = log --cc -1 HEAD
	lastfs = log --stat --cc -1 HEAD
	lg = log --graph --decorate
	lgold = log --graph --decorate --abbrev-commit
	lga = log --graph --decorate --abbrev-commit --all
	graph = log --graph --decorate --oneline

[color]
	branch = auto
	diff = auto
	status = auto

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red
	new = cyan

[diff]
	algorithm = patience
	wsErrorHighlight = all

[rerere]
	enabled = true

[branch]
	sort = -committerdate

[column]
	ui = auto
