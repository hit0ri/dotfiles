# ~/.zshrc - interactive shell config
# Load order: zshenv -> zprofile (login) -> zshrc (interactive) -> zlogin (login)

#-------------------------------------------------
# Shell options
#-------------------------------------------------

# Stops zsh-autosuggestions rebinding widgets on every precmd
ZSH_AUTOSUGGEST_MANUAL_REBIND=1

# ctrl+w stops at path separators, dots, hyphens; treats _ as part of a word
WORDCHARS='*?_[]~&;!#$%^(){}<>'

HISTFILE="${ZDOTDIR:-$HOME}/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000

setopt hist_ignore_all_dups
setopt hist_ignore_space
setopt hist_reduce_blanks
setopt hist_verify
setopt hist_save_no_dups
setopt hist_fcntl_lock
setopt share_history
setopt interactive_comments
setopt no_beep

#-------------------------------------------------
# PATH
#-------------------------------------------------

typeset -U path PATH
path=(
  ~/.krew/bin
  ~/.cargo/bin
  ~/.local/bin
  ~/.rd/bin
  $path
)
export PATH

{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{- end }}

#-------------------------------------------------
# zinit
#-------------------------------------------------

# Cache .zcompdump under XDG_CACHE_HOME and use `compinit -C` to skip the
# security check on each startup (cache is regenerated on plugin updates).
typeset -A ZINIT
ZINIT[ZCOMPDUMP_PATH]="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/.zcompdump"
ZINIT[COMPINIT_OPTS]="-C"

source ~/.local/share/zinit/zinit.git/zinit.zsh

#-------------------------------------------------
# Environment
#-------------------------------------------------

export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_BAT=1
export HOMEBREW_NO_ENV_HINTS=1
export HOMEBREW_BUNDLE_FILE=~/.brewfile

export npm_config_prefix=~/.node_modules # keeps npm -g out of /usr/local
export NVIM_APPNAME=nvim-lazy
export K9S_CONFIG_DIR="$HOME/.config/k9s"
export DIFFPROG='nvim -d'
export GROFF_NO_SGR=yes
export AWS_PAGER=

export TG_PROVIDER_CACHE=true
export TG_EXPERIMENT=dependency-fetch-output-from-state
export BUILDKIT_PROGRESS=plain
export ZELLIJ_AUTO_EXIT=true
export WINEDLLOVERRIDES='winemenubuilder.exe,mscoree,mshtml='

{{ if eq .chezmoi.os "darwin" -}}
export CLICOLOR=1
export BROWSER=open
export ANDROID_HOME="$HOME/Library/Android/sdk"
export K3D_FIX_DNS=0
{{- end }}
{{ if eq .chezmoi.os "linux" -}}
export S_COLORS=auto
{{- end }}

# Coloured man pages via less
export LESS_TERMCAP_mb=$'\e[1;31m'
export LESS_TERMCAP_md=$'\e[1;31m'
export LESS_TERMCAP_me=$'\e[0m'
export LESS_TERMCAP_ue=$'\e[0m'
export LESS_TERMCAP_us=$'\e[1;32m'

# secretive
export SSH_AUTH_SOCK=~/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/socket.ssh

#-------------------------------------------------
# fzf
#-------------------------------------------------

[[ -f ~/.config/fzf/themes/{{ (index .theme .current_theme).fzf }}.sh ]] && source ~/.config/fzf/themes/{{ (index .theme .current_theme).fzf }}.sh

() {
  local -a _excludes=(.git node_modules .venv venv .terraform .terragrunt-cache)

  if (($+commands[bfs])); then
    local _bfs_exclude=${(j: -o -name :)_excludes}
    export FZF_DEFAULT_COMMAND="bfs . -mindepth 1 \( -type f -o -type d \) -exclude \( -name ${_bfs_exclude} \) -printf '%P\n' 2>/dev/null"
    export FZF_ALT_C_COMMAND="bfs . -mindepth 1 -type d -exclude \( -name ${_bfs_exclude} \) -printf '%P\n' 2>/dev/null"
  elif (($+commands[fd])); then
    local _fd_exclude=${(j: --exclude :)_excludes}
    export FZF_DEFAULT_COMMAND="fd --hidden --exclude ${_fd_exclude} --type file --type directory"
    export FZF_ALT_C_COMMAND="fd --hidden --exclude ${_fd_exclude} --type directory"
  fi

  if ((${+commands[lsd]})); then
    local _ls='lsd --group-directories-first --color=always --icon=always'
  else
    local _ls='ls --color=always'
  fi

  export FZF_CTRL_T_OPTS="--bind ctrl-/:toggle-preview --preview 'if [[ -d {} ]]; then ${_ls} -1F {}; else bat --color=always --line-range :500 {}; fi' ${FZF_CTRL_T_OPTS}"
  export FZF_ALT_C_OPTS="--bind ctrl-/:toggle-preview --preview '${_ls} -1F {}' ${FZF_ALT_C_OPTS}"
}

((${+FZF_DEFAULT_COMMAND})) && export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

#-------------------------------------------------
# Tool initialisations
#-------------------------------------------------

# p10k and mise must be synchronous: p10k renders the prompt,
# mise sets up PATH for all managed tools.
# p10k config must be sourced before the plugin loads.
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh
zinit ice depth=1; zinit light romkatv/powerlevel10k
eval "$(mise activate zsh)"

#-------------------------------------------------
# Completion zstyles
#-------------------------------------------------

{{ if eq .chezmoi.os "darwin" -}}
fpath+=("$HOMEBREW_PREFIX/share/zsh/site-functions")
{{- end }}

# Must be set before the zstyle list-colors below references it
(($+commands[vivid])) && export LS_COLORS="$(vivid generate {{ (index .theme .current_theme).vivid }})"

zmodload zsh/complist
zstyle ':completion:*' completer _extensions _complete _files
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu select
zstyle ':completion:*' use-cache true
zstyle ':completion:*' cache-path "${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompcache"
zstyle ':completion:*' group-name ''
zstyle ':completion:*' verbose true
zstyle ':completion:*' squeeze-slashes true
zstyle ':completion:*' special-dirs true
zstyle ':completion:*' rehash true
zstyle ':completion:*:descriptions' format '%F{yellow}-- %d --%f'
zstyle ':completion:*:warnings' format '%F{red}-- no matches found --%f'
zstyle ':completion:*:default' list-prompt '%S%M matches%s'
zstyle ':completion:*:functions' ignored-patterns '_*'

#-------------------------------------------------
# Plugins & completion (zinit turbo)
#-------------------------------------------------

# Load order matters here:
# - zsh-autosuggestions runs zicompinit + zicdreplay in atinit, so compdef
#   exists before any later entry needs it
# - zsh-completions follows with blockf to extend fpath
# - tool inits and bashcompinit run last; their compdef calls now resolve
_init_bash_completions() {
  autoload -Uz bashcompinit && bashcompinit
  (($+commands[aws_completer])) && complete -C aws_completer aws
  (($+commands[terraform]))     && complete -C terraform terraform
  (($+commands[terragrunt]))    && complete -C terragrunt terragrunt
  (($+commands[packer]))        && complete -C packer packer
}

# Load core completion and suggestion plugins SYNCHRONOUSLY
# This prevents IDE shell integrations from tracking the background 'cd'
# into the plugin directories when opening new panes.
zinit light-mode for \
  atinit'zicompinit; zicdreplay' atload'_zsh_autosuggest_start' \
    zsh-users/zsh-autosuggestions \
  blockf atpull'zinit creinstall -q .' \
    zsh-users/zsh-completions

# Load the rest of the tools ASYNCHRONOUSLY
zinit wait lucid light-mode for \
  id-as'fzf-init'     has'fzf'      nocompile  atload'eval "$(fzf --zsh)"'                        zdharma-continuum/null \
  id-as'zoxide-init'  has'zoxide'   nocompile  atload'eval "$(zoxide init zsh)"'                  zdharma-continuum/null \
  id-as'kubectl-comp' has'kubectl'  nocompile  atload'eval "$(kubectl completion zsh)"'           zdharma-continuum/null \
  id-as'uv-comp'      has'uv'       nocompile  atload'eval "$(uv generate-shell-completion zsh)"' zdharma-continuum/null \
  id-as'fnox-comp'    has'fnox'     nocompile  atload'eval "$(fnox completion zsh)"'              zdharma-continuum/null \
  id-as'fnox-init'    has'fnox'     nocompile  atload'eval "$(fnox activate zsh)"'                zdharma-continuum/null \
  id-as'bash-comp'                  nocompile  atload'_init_bash_completions'                     zdharma-continuum/null

#-------------------------------------------------
# Keybindings
#-------------------------------------------------

bindkey -e
KEYTIMEOUT=10

autoload -Uz up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search

# Both terminfo and hardcoded ANSI for portability across terminals
bindkey "${terminfo[kcuu1]}" up-line-or-beginning-search
bindkey '^[[A' up-line-or-beginning-search
bindkey "${terminfo[kcud1]}" down-line-or-beginning-search
bindkey '^[[B' down-line-or-beginning-search
bindkey "${terminfo[kcbt]}" reverse-menu-complete
bindkey '^[[Z' reverse-menu-complete

#-------------------------------------------------
# Aliases
#-------------------------------------------------

alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

alias vim='nvim'
alias docker='podman'
alias jq='jaq'
alias k='kubectl'
alias lg='lazygit'

if (($+commands[lsd])); then
  alias ls='lsd --group-directories-first --icon=never'
else
  alias ls='ls --color=auto'
fi
alias ll='ls -lh'

alias batp='bat --paging=auto'
alias dig='dig +noall +answer +stats'
alias gap='git add --patch'
alias grep='grep --color=auto'
{{ if eq .chezmoi.os "linux" -}}
alias lsports='ss -tunalp | column -t'
{{ else -}}
alias lsports='lsof -iTCP -sTCP:LISTEN -nP'
{{- end }}

#-------------------------------------------------
# Integrations
#-------------------------------------------------

zinit wait lucid for \
  id-as'functions'  has'curl'  nocompile  atload'source ~/.functions.sh'            zdharma-continuum/null \
  id-as'op-plugins'            nocompile  if'[[ -f ~/.config/op/plugins.sh ]]' \
                                          atload'source ~/.config/op/plugins.sh'    zdharma-continuum/null
